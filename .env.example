# ============================================================================
# Source: .env.example
# Version: 1.0.0 — 2026-04-16
# Why: Template for all required environment variables — copy to .env and fill
# Env / Identity: Shell environment / Docker env_file
# ============================================================================

# ---------------------------------------------------------------------------
# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
# Enable inline mode: /setinline  |  Set inline hint: /setinlinehints
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=8797750100:465a4sd6a4sd6a4sd6as4d6as4d6
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# Use 'webhook' for production, 'polling' for local dev without a public URL
BOT_MODE=polling

# ---------------------------------------------------------------------------
# OpenAI Configuration
# Get your key at: https://platform.openai.com/api-keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini        # Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7
OPENAI_SYSTEM_PROMPT=You are a helpful assistant. Be concise and clear.

# ---------------------------------------------------------------------------
# Image Generation Configuration
# ---------------------------------------------------------------------------
# Provider to use: 'replicate' or 'fal'
IMAGE_PROVIDER=replicate

# Replicate API token — https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# fal.ai API key — https://fal.ai/dashboard
FAL_API_KEY=...

# Flux model to use:
#   Replicate: black-forest-labs/flux-schnell, black-forest-labs/flux-dev, black-forest-labs/flux-pro
#   fal.ai:    fal-ai/flux/schnell, fal-ai/flux/dev, fal-ai/flux-pro
FLUX_MODEL=black-forest-labs/flux-schnell
FLUX_IMAGE_SIZE=1024x1024        # Image dimensions
FLUX_STYLE_PREFIX=               # Optional prompt prefix (e.g. "photorealistic, 8k, ")

# ---------------------------------------------------------------------------
# Database Configuration
# SQLite for local dev — PostgreSQL for production
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./bot.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb

# ---------------------------------------------------------------------------
# Redis Configuration (for Celery task queue + rate limiter cache)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Admin Panel Authentication
# CHANGE THESE IN PRODUCTION — never use defaults
# ---------------------------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately
SECRET_KEY=generate_a_long_random_secret_key_here_min_32_chars

# Session expiry in hours
SESSION_EXPIRE_HOURS=24

# ---------------------------------------------------------------------------
# Rate Limiting
# Applied per-user sliding window
# ---------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=20    # Max requests per window
RATE_LIMIT_WINDOW=60      # Window size in seconds

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
APP_ENV=development           # development | production
DEBUG=true                    # Enable debug logging
LOG_LEVEL=INFO

# Maintenance mode — returns friendly message to all bot users
MAINTENANCE_MODE=false

# Allowed users whitelist: comma-separated Telegram user IDs
# Leave empty to allow ALL users
ALLOWED_USERS=
